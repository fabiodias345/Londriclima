NODE_ENV=production
PORT=3000
API_PREFIX=api/v1
APP_PUBLIC_URL=https://airmovebr.com.br

POSTGRES_DB=londriclima_prod
POSTGRES_USER=londriclima_prod
POSTGRES_PASSWORD=trocar-por-senha-forte
DATABASE_URL=postgresql://londriclima_prod:trocar-por-senha-forte@postgres:5432/londriclima_prod?schema=public

JWT_ACCESS_SECRET=trocar-por-secret-longo-e-aleatorio
JWT_REFRESH_SECRET=trocar-por-outro-secret-longo-e-aleatorio
JWT_ACCESS_EXPIRES_IN_SECONDS=900
JWT_REFRESH_EXPIRES_IN_SECONDS=2592000

AUTOMACOES_WORKER_ENABLED=true
AUTOMACOES_WORKER_INTERVAL_MS=30000
AUTOMACOES_WORKER_BATCH_SIZE=10
SMTP_HOST=smtp.exemplo.com.br
SMTP_PORT=587
SMTP_SECURE=false
SMTP_STARTTLS=true
SMTP_HELO_DOMAIN=airmovebr.com.br
SMTP_FROM=AIRMOVEBR <noreply@airmovebr.com.br>
SMTP_USER=usuario-smtp
SMTP_PASS=trocar-por-senha-smtp
