model Orcamento {
  id                 String          @id @default(uuid()) @db.Uuid
  empresaId          String          @map("empresa_id") @db.Uuid
  clienteId          String          @map("cliente_id") @db.Uuid
  conversaId         String?         @map("conversa_id") @db.Uuid
  criadoPorUsuarioId String?         @map("criado_por_usuario_id") @db.Uuid
  status             OrcamentoStatus @default(rascunho)
  titulo             String
  detalhes           String?
  validoAte          DateTime?       @map("valido_ate")
  subtotal           Decimal         @default(0) @db.Decimal(12, 2)
  desconto           Decimal         @default(0) @db.Decimal(12, 2)
  total              Decimal         @default(0) @db.Decimal(12, 2)
  enviadoEm          DateTime?       @map("enviado_em")
  criadoEm           DateTime        @default(now()) @map("criado_em")
  atualizadoEm       DateTime        @updatedAt @map("atualizado_em")

  empresa   Empresa           @relation(fields: [empresaId], references: [id])
  cliente   Cliente           @relation(fields: [clienteId], references: [id])
  conversa  WhatsAppConversa? @relation(fields: [conversaId], references: [id], onDelete: SetNull)
  criadoPor Usuario?          @relation("OrcamentoCriador", fields: [criadoPorUsuarioId], references: [id], onDelete: SetNull)
  itens     OrcamentoItem[]

  @@index([empresaId, status])
  @@index([clienteId])
  @@index([conversaId])
  @@map("orcamentos")
}

model OrcamentoItem {
  id             String           @id @default(uuid()) @db.Uuid
  orcamentoId    String           @map("orcamento_id") @db.Uuid
  itemCatalogoId String?          @map("item_catalogo_id") @db.Uuid
  tipo           CatalogoItemTipo
  descricao      String
  unidade        String
  quantidade     Decimal          @db.Decimal(12, 3)
  valorUnitario  Decimal          @map("valor_unitario") @db.Decimal(12, 2)
  valorTotal     Decimal          @map("valor_total") @db.Decimal(12, 2)
  criadoEm       DateTime         @default(now()) @map("criado_em")

  orcamento    Orcamento     @relation(fields: [orcamentoId], references: [id], onDelete: Cascade)
  itemCatalogo CatalogoItem? @relation(fields: [itemCatalogoId], references: [id], onDelete: SetNull)

  @@index([orcamentoId])
  @@map("orcamento_itens")
}
model WhatsAppConversa {
  id                 String                @id @default(uuid()) @db.Uuid
  empresaId          String                @map("empresa_id") @db.Uuid
  telefone           String
  nomeContato        String?               @map("nome_contato")
  status             WhatsAppConversaStatus @default(bot)
  dados              Json?
  ultimaMensagemEm   DateTime              @default(now()) @map("ultima_mensagem_em")
  ultimaLeituraEm    DateTime?             @map("ultima_leitura_em")
  atribuidoUsuarioId String?               @map("atribuido_usuario_id") @db.Uuid
  clienteId          String?               @map("cliente_id") @db.Uuid
  ordemServicoId     String?               @unique @map("ordem_servico_id") @db.Uuid
  encerramentoMotivo String?               @map("encerramento_motivo")
  criadoEm           DateTime              @default(now()) @map("criado_em")
  atualizadoEm       DateTime              @updatedAt @map("atualizado_em")

  empresa          Empresa     @relation(fields: [empresaId], references: [id])
  atribuidoUsuario Usuario?    @relation("WhatsAppConversaAtendente", fields: [atribuidoUsuarioId], references: [id], onDelete: SetNull)
  cliente          Cliente?    @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  ordemServico     OrdemServico? @relation(fields: [ordemServicoId], references: [id], onDelete: SetNull)
  mensagens        WhatsAppMensagem[]
  orcamentos       Orcamento[]

  @@unique([empresaId, telefone])
  @@index([empresaId, status, ultimaMensagemEm])
  @@map("whatsapp_conversas")
}

model WhatsAppMensagem {
  id          String                 @id @default(uuid()) @db.Uuid
  conversaId  String                 @map("conversa_id") @db.Uuid
  direcao     WhatsAppMensagemDirecao
  texto       String
  mensagemId  String?                @unique @map("mensagem_id")
  tipo        String                 @default("text")
  statusEntrega    String?                @map("status_entrega")
  statusEntregaEm  DateTime?              @map("status_entrega_em")
  criadoEm    DateTime               @default(now()) @map("criado_em")

  conversa WhatsAppConversa @relation(fields: [conversaId], references: [id], onDelete: Cascade)

  @@index([conversaId, criadoEm])
  @@map("whatsapp_mensagens")
}
