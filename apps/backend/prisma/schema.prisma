generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UsuarioRole {
  admin
  supervisor
  tecnico
  auxiliar
}

enum EquipeMembroFuncao {
  lider
  tecnico
  auxiliar
}

enum OrdemServicoResponsavelTipo {
  usuario
  equipe
}

enum PessoaTipo {
  pf
  pj
}

enum OrdemServicoStatus {
  pre_chamado
  rejeitada
  aberta
  em_deslocamento
  em_atendimento
  cancelada
  concluida
}

enum OrdemServicoEventoAcao {
  criar_pre_chamado
  aprovar
  rejeitar
  iniciar_rota
  iniciar_atendimento
  cheguei_cliente
  cancelar
  finalizar
}

enum EvidenciaTipo {
  antes
  depois
}

enum AutomacaoTipo {
  gerar_pdf
  enviar_email
  enviar_whatsapp
  recorrencia_180_dias
}

enum AutomacaoStatus {
  pendente
  processando
  concluida
  falhou
  cancelada
}

enum PmocRelatorioStatus {
  gerado
  aguardando_assinatura_engenheiro
  assinado
  cancelado
}

enum PlanoRecorrenciaFrequencia {
  mensal
  trimestral
  semestral
  anual
}

enum ChecklistTipo {
  mensal
  trimestral
  semestral
  anual
}

enum OrdemServicoTipoServico {
  preventiva
  corretiva
  instalacao
}

enum CategoriaAtendimento {
  ar_condicionado
  camara_fria
}

enum WhatsAppConversaStatus {
  bot
  humano
  encerrada
}

enum WhatsAppMensagemDirecao {
  entrada
  saida
}

enum CatalogoItemTipo {
  servico
  material
  peca
  equipamento
}

enum OrcamentoStatus {
  rascunho
  enviado
  aprovado
  recusado
  expirado
}

model Empresa {
  id                 String   @id @default(uuid()) @db.Uuid
  nome               String
  razaoSocial        String?  @map("razao_social")
  nomeFantasia       String?  @map("nome_fantasia")
  cnpj               String?  @unique
  telefone           String?
  email              String?
  logradouro         String?
  numero             String?
  complemento        String?
  bairro             String?
  cidade             String?
  uf                 String?  @db.Char(2)
  cep                String?
  inscricaoEstadual  String?  @map("inscricao_estadual")
  inscricaoMunicipal String?  @map("inscricao_municipal")
  responsavelLegal   String?  @map("responsavel_legal")
  responsavelCpf     String?  @map("responsavel_cpf")
  contatoPrincipal   String?  @map("contato_principal")
  contatoCargo       String?  @map("contato_cargo")
  status             String   @default("ativa")
  observacoes        String?
  ativa              Boolean  @default(true)
  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  usuarios                  Usuario[]
  equipes                   Equipe[]
  clientes                  Cliente[]
  engenheirosResponsaveis   EngenheiroResponsavel[]
  equipamentos              Equipamento[]
  ordensServico             OrdemServico[]
  automacoes                AutomacaoAgendada[]
  veiculos                  Veiculo[]
  veiculoLocalizacoes       VeiculoLocalizacao[]
  veiculoAbastecimentos     VeiculoAbastecimento[]
  pmocRelatorios            PmocRelatorio[]
  planosRecorrencia         PlanoRecorrencia[]
  planosRecorrenciaGeracoes PlanoRecorrenciaGeracao[]
  funcionarioDocumentos     FuncionarioDocumento[]
  convitesTecnico           ConviteTecnico[]
  conversasWhatsApp         WhatsAppConversa[]
  catalogoItens             CatalogoItem[]
  orcamentos                Orcamento[]

  @@map("empresas")
}

model Usuario {
  id                     String      @id @default(uuid()) @db.Uuid
  empresaId              String      @map("empresa_id") @db.Uuid
  nome                   String
  login                  String?     @unique
  email                  String
  telefone               String?
  cpf                    String?
  senhaHash              String      @map("senha_hash")
  role                   UsuarioRole
  ativo                  Boolean     @default(true)
  fotoPerfilStorageUrl   String?     @map("foto_perfil_storage_url")
  assinaturaStorageUrl   String?     @map("assinatura_storage_url")
  primeiroAcessoPendente Boolean     @default(false) @map("primeiro_acesso_pendente")
  primeiroAcessoEm       DateTime?   @map("primeiro_acesso_em")
  ultimoLoginEm          DateTime?   @map("ultimo_login_em")
  criadoEm               DateTime    @default(now()) @map("criado_em")
  atualizadoEm           DateTime    @updatedAt @map("atualizado_em")

  empresa                  Empresa                   @relation(fields: [empresaId], references: [id])
  equipesTecnico           Equipe[]                  @relation("EquipeTecnico")
  equipesMembro            EquipeMembro[]
  clientesResponsavel      Cliente[]                 @relation("ClienteTecnicoResponsavel")
  ordensComoTecnico        OrdemServico[]            @relation("OrdemTecnico")
  ordensResponsavel        OrdemServicoResponsavel[]
  planosRecorrenciaTecnico PlanoRecorrencia[]        @relation("PlanoRecorrenciaTecnico")
  eventos                  OrdemServicoEvento[]
  segurancas               OrdemServicoSeguranca[]
  veiculoAbastecimentos    VeiculoAbastecimento[]
  conversasWhatsApp        WhatsAppConversa[] @relation("WhatsAppConversaAtendente")
  pmocRelatoriosCriados    PmocRelatorio[]           @relation("PmocRelatorioCriador")
  documentosFuncionario    FuncionarioDocumento[]
  convitesTecnicoCriados   ConviteTecnico[]          @relation("ConviteTecnicoCriador")
  conviteTecnicoConsumido  ConviteTecnico?           @relation("ConviteTecnicoUsuario")
  orcamentosCriados       Orcamento[]               @relation("OrcamentoCriador")

  @@unique([empresaId, email])
  @@unique([empresaId, cpf])
  @@index([empresaId])
  @@map("usuarios")
}

model ConviteTecnico {
  id              String    @id @default(uuid()) @db.Uuid
  empresaId       String    @map("empresa_id") @db.Uuid
  criadoPorId     String?   @map("criado_por_id") @db.Uuid
  role            UsuarioRole
  codigoHash      String    @unique @map("codigo_hash")
  codigoSufixo    String    @map("codigo_sufixo") @db.Char(4)
  expiraEm        DateTime  @map("expira_em")
  canceladoEm     DateTime? @map("cancelado_em")
  usadoEm         DateTime? @map("usado_em")
  usuarioCriadoId String?   @unique @map("usuario_criado_id") @db.Uuid
  criadoEm        DateTime  @default(now()) @map("criado_em")

  empresa       Empresa  @relation(fields: [empresaId], references: [id])
  criadoPor     Usuario? @relation("ConviteTecnicoCriador", fields: [criadoPorId], references: [id], onDelete: SetNull)
  usuarioCriado Usuario? @relation("ConviteTecnicoUsuario", fields: [usuarioCriadoId], references: [id], onDelete: SetNull)

  @@index([empresaId, criadoEm])
  @@index([expiraEm])
  @@map("convites_tecnico")
}

model FuncionarioDocumento {
  id              String   @id @default(uuid()) @db.Uuid
  empresaId       String   @map("empresa_id") @db.Uuid
  usuarioId       String   @map("usuario_id") @db.Uuid
  tipo            String
  versao          String
  nomeFuncionario String   @map("nome_funcionario")
  cpf             String
  storageUrl      String   @map("storage_url")
  sha256          String
  aceitoEm        DateTime @map("aceito_em")
  criadoEm        DateTime @default(now()) @map("criado_em")

  empresa Empresa @relation(fields: [empresaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, tipo, versao])
  @@index([empresaId])
  @@index([usuarioId])
  @@map("funcionario_documentos")
}

model Equipe {
  id           String   @id @default(uuid()) @db.Uuid
  empresaId    String   @map("empresa_id") @db.Uuid
  nome         String
  tecnicoId    String?  @map("tecnico_id") @db.Uuid
  ativa        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa           Empresa                   @relation(fields: [empresaId], references: [id])
  tecnico           Usuario?                  @relation("EquipeTecnico", fields: [tecnicoId], references: [id], onDelete: SetNull)
  auxiliares        EquipeAuxiliar[]
  membros           EquipeMembro[]
  clientes          ClienteEquipe[]
  ordensServico     OrdemServico[]
  ordensResponsavel OrdemServicoResponsavel[]
  planosRecorrencia PlanoRecorrencia[]

  @@index([empresaId])
  @@map("equipes")
}

model EquipeMembro {
  id           String             @id @default(uuid()) @db.Uuid
  empresaId    String             @map("empresa_id") @db.Uuid
  equipeId     String             @map("equipe_id") @db.Uuid
  usuarioId    String             @map("usuario_id") @db.Uuid
  funcao       EquipeMembroFuncao
  ativo        Boolean            @default(true)
  criadoEm     DateTime           @default(now()) @map("criado_em")
  atualizadoEm DateTime           @updatedAt @map("atualizado_em")

  equipe  Equipe  @relation(fields: [equipeId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([equipeId, usuarioId])
  @@index([empresaId])
  @@index([usuarioId])
  @@map("equipe_membros")
}

model EquipeAuxiliar {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  equipeId  String   @map("equipe_id") @db.Uuid
  nome      String
  telefone  String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  equipe Equipe @relation(fields: [equipeId], references: [id])

  @@index([empresaId])
  @@index([equipeId])
  @@map("equipe_auxiliares")
}

model Cliente {
  id                      String     @id @default(uuid()) @db.Uuid
  empresaId               String     @map("empresa_id") @db.Uuid
  tipo                    PessoaTipo
  nome                    String
  documento               String?
  email                   String?
  telefone                String?
  pmocAtivo               Boolean    @default(false) @map("pmoc_ativo")
  pmocArtNumero           String?    @map("pmoc_art_numero")
  engenheiroResponsavelId String?    @map("engenheiro_responsavel_id") @db.Uuid
  tecnicoResponsavelId    String?    @map("tecnico_responsavel_id") @db.Uuid
  criadoEm                DateTime   @default(now()) @map("criado_em")
  atualizadoEm            DateTime   @updatedAt @map("atualizado_em")

  empresa               Empresa                @relation(fields: [empresaId], references: [id])
  engenheiroResponsavel EngenheiroResponsavel? @relation(fields: [engenheiroResponsavelId], references: [id])
  tecnicoResponsavel    Usuario?               @relation("ClienteTecnicoResponsavel", fields: [tecnicoResponsavelId], references: [id], onDelete: SetNull)
  equipes               ClienteEquipe[]
  enderecos             ClienteEndereco[]
  equipamentos          Equipamento[]
  ordensServico         OrdemServico[]
  pmocRelatorios        PmocRelatorio[]
  planosRecorrencia     PlanoRecorrencia[]
  conversasWhatsApp     WhatsAppConversa[]
  orcamentos            Orcamento[]

  @@index([empresaId])
  @@index([empresaId, pmocAtivo])
  @@index([empresaId, documento])
  @@index([tecnicoResponsavelId])
  @@map("clientes")
}

model ClienteEquipe {
  id        String   @id @default(uuid()) @db.Uuid
  empresaId String   @map("empresa_id") @db.Uuid
  clienteId String   @map("cliente_id") @db.Uuid
  equipeId  String   @map("equipe_id") @db.Uuid
  principal Boolean  @default(false)
  criadoEm  DateTime @default(now()) @map("criado_em")

  cliente Cliente @relation(fields: [clienteId], references: [id])
  equipe  Equipe  @relation(fields: [equipeId], references: [id])

  @@unique([clienteId, equipeId])
  @@index([empresaId])
  @@index([equipeId])
  @@map("cliente_equipes")
}

model EngenheiroResponsavel {
  id           String   @id @default(uuid()) @db.Uuid
  empresaId    String   @map("empresa_id") @db.Uuid
  nome         String
  cpf          String
  crea         String
  email        String
  telefone     String?
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  empresa        Empresa         @relation(fields: [empresaId], references: [id])
  clientes       Cliente[]
  pmocRelatorios PmocRelatorio[]

  @@unique([empresaId, crea])
  @@index([empresaId])
  @@map("engenheiros_responsaveis")
}

model PmocRelatorio {
  id                      String              @id @default(uuid()) @db.Uuid
  empresaId               String              @map("empresa_id") @db.Uuid
  clienteId               String              @map("cliente_id") @db.Uuid
  engenheiroResponsavelId String              @map("engenheiro_responsavel_id") @db.Uuid
  criadoPorUsuarioId      String?             @map("criado_por_usuario_id") @db.Uuid
  status                  PmocRelatorioStatus @default(gerado)
  tokenAssinatura         String              @unique @map("token_assinatura")
  pdfHash                 String              @map("pdf_hash")
  pdfStorageUrl           String?             @map("pdf_storage_url")
  pdfDriveUrl             String?             @map("pdf_drive_url")
  assinafyDocumentId      String?             @unique @map("assinafy_document_id")
  assinafyAssignmentId    String?             @map("assinafy_assignment_id")
  assinafyStatus          String?             @map("assinafy_status")
  assinafyUltimoEvento    Json?               @map("assinafy_ultimo_evento")
  assinadoEm              DateTime?           @map("assinado_em")
  emailCliente            String?             @map("email_cliente")
  emailAgendadoEm         DateTime?           @map("email_agendado_em")
  historicoFinalizadoEm   DateTime?           @map("historico_finalizado_em")
  criadoEm                DateTime            @default(now()) @map("criado_em")
  atualizadoEm            DateTime            @updatedAt @map("atualizado_em")

  empresa               Empresa               @relation(fields: [empresaId], references: [id])
  cliente               Cliente               @relation(fields: [clienteId], references: [id])
  engenheiroResponsavel EngenheiroResponsavel @relation(fields: [engenheiroResponsavelId], references: [id])
  criadoPorUsuario      Usuario?              @relation("PmocRelatorioCriador", fields: [criadoPorUsuarioId], references: [id], onDelete: SetNull)

  @@index([empresaId, clienteId])
  @@index([empresaId, status])
  @@map("pmoc_relatorios")
}

model ClienteEndereco {
  id           String   @id @default(uuid()) @db.Uuid
  empresaId    String   @map("empresa_id") @db.Uuid
  clienteId    String   @map("cliente_id") @db.Uuid
  nome         String?
  logradouro   String
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String
  uf           String
  cep          String?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  principal    Boolean  @default(false)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  cliente       Cliente        @relation(fields: [clienteId], references: [id])
  ordensServico OrdemServico[]

  @@index([empresaId])
  @@index([clienteId])
  @@map("cliente_enderecos")
}

model Equipamento {
  id                         String               @id @default(uuid()) @db.Uuid
  empresaId                  String               @map("empresa_id") @db.Uuid
  clienteId                  String               @map("cliente_id") @db.Uuid
  categoria                  CategoriaAtendimento @default(ar_condicionado)
  codigoPublico              String?              @unique @map("codigo_publico")
  senhaPublicaHash           String?              @map("senha_publica_hash")
  acessoPublicoAtivo         Boolean              @default(false) @map("acesso_publico_ativo")
  tipo                       String?
  patrimonio                 String?
  codigoBarras               String?              @map("codigo_barras")
  marca                      String
  modelo                     String
  capacidadeBtu              Int?                 @map("capacidade_btu")
  gasRefrigerante            String?              @map("gas_refrigerante")
  numeroSerie                String?              @map("numero_serie")
  localInstalacao            String?              @map("local_instalacao")
  dadosPendentesJustificados Json?                @map("dados_pendentes_justificados")
  areaClimatizadaM2          Int?                 @map("area_climatizada_m2")
  ocupantesFixo              Int?                 @map("ocupantes_fixo")
  ocupantesVariavel          Int?                 @map("ocupantes_variavel")
  criadoEm                   DateTime             @default(now()) @map("criado_em")
  atualizadoEm               DateTime             @updatedAt @map("atualizado_em")

  empresa            Empresa                         @relation(fields: [empresaId], references: [id])
  cliente            Cliente                         @relation(fields: [clienteId], references: [id])
  ordensServico      OrdemServico[]
  checklistRespostas OrdemServicoChecklistResposta[]
  planosRecorrencia  PlanoRecorrencia[]

  @@index([empresaId])
  @@index([clienteId])
  @@index([empresaId, codigoBarras])
  @@index([empresaId, patrimonio])
  @@map("equipamentos")
}

model OrdemServico {
  id               String                  @id @default(uuid()) @db.Uuid
  empresaId        String                  @map("empresa_id") @db.Uuid
  clienteId        String                  @map("cliente_id") @db.Uuid
  enderecoId       String?                 @map("endereco_id") @db.Uuid
  equipamentoId    String?                 @map("equipamento_id") @db.Uuid
  equipeId         String?                 @map("equipe_id") @db.Uuid
  tecnicoId        String?                 @map("tecnico_id") @db.Uuid
  status           OrdemServicoStatus      @default(pre_chamado)
  categoriaServico CategoriaAtendimento    @default(ar_condicionado) @map("categoria_servico")
  tipoServico      OrdemServicoTipoServico @default(preventiva) @map("tipo_servico")
  checklistTipo    ChecklistTipo           @default(mensal) @map("checklist_tipo")
  titulo           String
  problemaRelatado String?                 @map("problema_relatado")
  agendadaPara     DateTime?               @map("agendada_para")
  valorCobrado     Decimal?                @map("valor_cobrado") @db.Decimal(12, 2)
  criadaEm         DateTime                @default(now()) @map("criada_em")
  atualizadaEm     DateTime                @updatedAt @map("atualizada_em")
  concluidaEm      DateTime?               @map("concluida_em")

  empresa                  Empresa                         @relation(fields: [empresaId], references: [id])
  cliente                  Cliente                         @relation(fields: [clienteId], references: [id])
  endereco                 ClienteEndereco?                @relation(fields: [enderecoId], references: [id])
  equipamento              Equipamento?                    @relation(fields: [equipamentoId], references: [id])
  equipe                   Equipe?                         @relation(fields: [equipeId], references: [id])
  tecnico                  Usuario?                        @relation("OrdemTecnico", fields: [tecnicoId], references: [id], onDelete: SetNull)
  responsaveis             OrdemServicoResponsavel[]
  eventos                  OrdemServicoEvento[]
  evidencias               OrdemServicoEvidencia[]
  checklist                OrdemServicoChecklist?
  checklistRespostas       OrdemServicoChecklistResposta[]
  assinatura               OrdemServicoAssinatura?
  observacoes              OrdemServicoObservacao[]
  segurancas               OrdemServicoSeguranca[]
  automacoes               AutomacaoAgendada[]
  planosRecorrenciaGerada  PlanoRecorrencia[]              @relation("PlanoRecorrenciaUltimaOs")
  planoRecorrenciaGeracoes PlanoRecorrenciaGeracao[]
  conversaWhatsApp          WhatsAppConversa?

  @@index([empresaId, status])
  @@index([empresaId, agendadaPara])
  @@index([clienteId])
  @@map("ordens_servico")
}

model OrdemServicoSeguranca {
  id             String   @id @default(uuid()) @db.Uuid
  empresaId      String   @map("empresa_id") @db.Uuid
  ordemServicoId String   @map("ordem_servico_id") @db.Uuid
  usuarioId      String?  @map("usuario_id") @db.Uuid
  respostas      Json
  aprovado       Boolean
  motivoBloqueio String?  @map("motivo_bloqueio")
  versao         Int      @default(1)
  latitude       Decimal  @db.Decimal(10, 7)
  longitude      Decimal  @db.Decimal(10, 7)
  registradoEm   DateTime @map("registrado_em")
  criadoEm       DateTime @default(now()) @map("criado_em")

  ordemServico OrdemServico @relation(fields: [ordemServicoId], references: [id])
  usuario      Usuario?     @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([empresaId])
  @@index([ordemServicoId])
  @@index([usuarioId])
  @@map("ordem_servico_segurancas")
}

model PlanoRecorrencia {
  id              String                     @id @default(uuid()) @db.Uuid
  empresaId       String                     @map("empresa_id") @db.Uuid
  clienteId       String                     @map("cliente_id") @db.Uuid
  equipamentoId   String?                    @map("equipamento_id") @db.Uuid
  equipeId        String?                    @map("equipe_id") @db.Uuid
  tecnicoId       String?                    @map("tecnico_id") @db.Uuid
  ultimoOsId      String?                    @map("ultimo_os_id") @db.Uuid
  titulo          String
  detalhes        String?
  frequencia      PlanoRecorrenciaFrequencia
  checklistTipo   ChecklistTipo              @default(mensal) @map("checklist_tipo")
  calendario      Json                       @default("{}")
  diaGeracao      Int                        @default(1) @map("dia_geracao")
  proximaExecucao DateTime                   @map("proxima_execucao")
  valorCobrado    Decimal?                   @map("valor_cobrado") @db.Decimal(12, 2)
  ativo           Boolean                    @default(true)
  criadoEm        DateTime                   @default(now()) @map("criado_em")
  atualizadoEm    DateTime                   @updatedAt @map("atualizado_em")

  empresa     Empresa                   @relation(fields: [empresaId], references: [id])
  cliente     Cliente                   @relation(fields: [clienteId], references: [id])
  equipamento Equipamento?              @relation(fields: [equipamentoId], references: [id])
  equipe      Equipe?                   @relation(fields: [equipeId], references: [id])
  tecnico     Usuario?                  @relation("PlanoRecorrenciaTecnico", fields: [tecnicoId], references: [id], onDelete: SetNull)
  ultimoOs    OrdemServico?             @relation("PlanoRecorrenciaUltimaOs", fields: [ultimoOsId], references: [id])
  geracoes    PlanoRecorrenciaGeracao[]

  @@index([empresaId, ativo, proximaExecucao])
  @@index([clienteId])
  @@index([equipamentoId])
  @@map("planos_recorrencia")
}

model PlanoRecorrenciaGeracao {
  id             String   @id @default(uuid()) @db.Uuid
  empresaId      String   @map("empresa_id") @db.Uuid
  planoId        String   @map("plano_id") @db.Uuid
  ordemServicoId String   @map("ordem_servico_id") @db.Uuid
  competenciaAno Int      @map("competencia_ano")
  competenciaMes Int      @map("competencia_mes")
  criadoEm       DateTime @default(now()) @map("criado_em")

